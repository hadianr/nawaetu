{
    "manifest_version": 3,
    "name": "Nawaetu",
    "version": "1.9.4",
    "description": "Jadwal sholat, countdown adzan, notifikasi, dan ayat Al-Quran harian – companion Muslim terpadu.",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png",
        "192": "icons/icon-192.png",
        "512": "icons/icon-512.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "side_panel": {
        "default_path": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "geolocation",
        "notifications",
        "alarms",
        "sidePanel"
    ]
}